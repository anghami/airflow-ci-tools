# Default MWAA Environment Variables
# These simulate the AWS MWAA runtime environment

# Core Airflow Configuration
AIRFLOW_HOME=/usr/local/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__LOAD_DEFAULT_CONNECTIONS=False
AIRFLOW__CORE__DAGS_FOLDER=/usr/local/airflow/dags
AIRFLOW__CORE__PLUGINS_FOLDER=/usr/local/airflow/plugins
AIRFLOW__CORE__PARALLELISM=32
AIRFLOW__CORE__DAG_CONCURRENCY=16
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16

# Database Configuration (SQLite for CI)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////usr/local/airflow/airflow.db

# Webserver Configuration
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080

# Scheduler Configuration
AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=300
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=30

# Logging Configuration
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW__LOGGING__FAB_LOGGING_LEVEL=WARNING

# Python Path
PYTHONPATH=/usr/local/airflow/dags:/usr/local/airflow/plugins